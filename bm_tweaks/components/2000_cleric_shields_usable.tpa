// Make all shields usable by cleric classes/multiclasses.
// Mirrors the existing class-bit clear pattern used in component 00_swords.
//
// Scope: ITM type 12 (shields) only.

COPY_EXISTING_REGEXP GLOB ~^.+\.itm$~ ~override~
  PATCH_IF (SOURCE_SIZE > 0x71) BEGIN
    READ_SHORT 0x1c item_type
    PATCH_IF (item_type = 12) BEGIN
      READ_LONG 0x1e unus
      WRITE_LONG 0x1e (unus BAND BNOT (BIT7 BOR BIT8 BOR BIT9))
    END
  END
BUT_ONLY_IF_IT_CHANGES
