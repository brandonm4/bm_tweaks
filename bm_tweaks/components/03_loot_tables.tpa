    ~^RNDTRI01[^\r\n]*$~
    ~RNDTRI01 RING10   RING11   RING14   AMUL05   AMUL06   BDAMUL24   *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *~
  REPLACE_TEXTUALLY
