// Primary target: RNDTRES.2DA, which is what live creature RNDTRE## refs
// resolve against in this install. Support tables get a light touch only.

COPY_EXISTING ~rndtres.2da~ ~override~
  REPLACE_TEXTUALLY
    ~^SODTRE07[^\r\n]*$~
    ~SODTRE07 BDRING07 BDRING09 BDRING12 BDAMUL25 BDAMUL24   *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *        *~
