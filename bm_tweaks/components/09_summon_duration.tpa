// --- Summon Deva / Fallen Deva innates — restricted to level 20 ---
ACTION_FOR_EACH spl IN SPPR726  SPPR727 BEGIN
  COPY_EXISTING ~%spl%.spl~ ~override~
    LPF BM_SUMMON_SCALE INT_VAR true_min = 20 END
