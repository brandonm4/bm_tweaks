// --- Level 9 spells (true_min 17) ---
ACTION_FOR_EACH spl IN
  SPWI905
  MEWI958  // MESpells: Phantasmal Dragon
BEGIN
  ACTION_IF FILE_EXISTS_IN_GAME ~%spl%.spl~ BEGIN
