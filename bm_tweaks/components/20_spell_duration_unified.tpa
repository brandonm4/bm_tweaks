// ---------------------------------------------------------------------------
// Description updates kept from old defensive component
// ---------------------------------------------------------------------------
DEFINE_ACTION_FUNCTION BM_UNIFIED_UPDATE_DESC
  INT_VAR desc_strref = 0
BEGIN
  ACTION_IF (desc_strref > 0) BEGIN
    ACTION_GET_STRREF desc_strref cur_text
    OUTER_PATCH_SAVE new_text ~%cur_text%~ BEGIN
      REPLACE_TEXTUALLY ~5 turns~ ~1 turn/level~
      REPLACE_TEXTUALLY ~5 turn~ ~1 turn/level~
      REPLACE_TEXTUALLY ~10 turns~ ~1 turn/level~
      REPLACE_TEXTUALLY ~Duration: 5 turns~ ~Duration: 1 turn/level~
      REPLACE_TEXTUALLY ~Duration : 5 turns~ ~Duration: 1 turn/level~
      REPLACE_TEXTUALLY ~Duration: 10 turns~ ~Duration: 1 turn/level~
      REPLACE_TEXTUALLY ~Duration : 10 turns~ ~Duration: 1 turn/level~
      REPLACE_TEXTUALLY ~Duration: 3 turns~ ~Duration: 1 turn/level~
      REPLACE_TEXTUALLY ~Duration : 3 turns~ ~Duration: 1 turn/level~
      REPLACE_TEXTUALLY ~Duration: 2 turns~ ~Duration: 1 turn/level~
      REPLACE_TEXTUALLY ~Duration : 2 turns~ ~Duration: 1 turn/level~
      REPLACE_TEXTUALLY ~Duration: 1 turn~ ~Duration: 1 turn/level~
      REPLACE_TEXTUALLY ~Duration : 1 turn~ ~Duration: 1 turn/level~
      REPLACE_TEXTUALLY ~Duration: 1 turn + 1 round/level~ ~Duration: 1 turn/level~
      REPLACE_TEXTUALLY ~Duration: 1 turn \+ 1 round/level~ ~Duration: 1 turn/level~
      REPLACE_TEXTUALLY ~Duration: 1 round/level~ ~Duration: 1 turn/level~
      REPLACE_TEXTUALLY ~Duration: 4 rounds~ ~Duration: 1 turn/level~
      REPLACE_TEXTUALLY ~Duration : 4 rounds~ ~Duration: 1 turn/level~
      REPLACE_TEXTUALLY ~Duration: 3 rounds~ ~Duration: 1 turn/level~
      REPLACE_TEXTUALLY ~Duration : 3 rounds~ ~Duration: 1 turn/level~
      REPLACE_TEXTUALLY ~Duration: 8 rounds + 1 round/level~ ~Duration: 1 turn/level~
      REPLACE_TEXTUALLY ~Duration: 8 rounds \+ 1 round/level~ ~Duration: 1 turn/level~
      REPLACE_TEXTUALLY ~Duration: 4 rounds + 1 round/level~ ~Duration: 1 turn/level~
      REPLACE_TEXTUALLY ~Duration: 4 rounds \+ 1 round/level~ ~Duration: 1 turn/level~
    END
    ACTION_IF NOT (~%cur_text%~ STRING_EQUAL ~%new_text%~) BEGIN
      STRING_SET_EVALUATE desc_strref ~%new_text%~
    END
  END
END

ACTION_FOR_EACH dsr IN
  63829 63831 226580 272198 272206 272207 272210 272214 272222 272225 272226 272248 272259 272267 272274 272282 272293 272294 272297 272299 272301 272302 272303 272307 272315 272323 272337 272339 272346 272347 272349 272361 272362 272368 272388 272396 272397 272410 272417 272418 272456 272463 272464 272466 272479 272487 272492 272493 272494 272495 272515 272524 272532 272534 272547 272551 272552 272555 272556 272557 272566 272579 272580 272581 272582 272584 272586 272588 272594 272606 272607 272612 272619 272635 272638 272866 273173 273174 273177 276188 276223 276241 276249 276255
BEGIN
  LAF BM_UNIFIED_UPDATE_DESC INT_VAR desc_strref = %dsr% END
END

