// Unified Spell Duration Scaling (replaces old components 09/10/17)
//
// Duration units are exposed as top-level variables to keep tuning centralized.
// Defaults below follow project convention for real-time scaling.

OUTER_SET OneRoundPerLevel = 6 * 15
OUTER_SET OneTurnPerLevel  = OneRoundPerLevel * 10
OUTER_SET OneHourPerLevel  = OneTurnPerLevel * 6
OUTER_SET RoundsPerTurn    = OneTurnPerLevel / OneRoundPerLevel

// ---------------------------------------------------------------------------
// Helpers
// ---------------------------------------------------------------------------

DEFINE_PATCH_FUNCTION BM_SCALE_OP177
  INT_VAR true_min = 1
          units_per_level = 0
BEGIN
  LPF FJ_SPL_ITM_REINDEX END

  GET_OFFSET_ARRAY ab_arr SPL_V10_HEADERS
  PHP_EACH ab_arr AS ab_idx => ab_off BEGIN
    READ_SHORT (ab_off + 0x10) ab_min_lvl
    SET eff_level = (ab_min_lvl <= 1) ? true_min : ab_min_lvl
    SET new_dur   = eff_level * units_per_level

    GET_OFFSET_ARRAY2 fx_arr ab_off SPL_V10_HEAD_EFFECTS
    PHP_EACH fx_arr AS fx_idx => fx_off BEGIN
      PATCH_IF (SHORT_AT fx_off = 177) BEGIN
        WRITE_LONG (fx_off + 0x0e) new_dur
      END
    END
  END

  FOR (new_lvl = true_min; new_lvl <= 20; ++new_lvl) BEGIN
    SET already_present = 0
    SET template_idx = "-1"
    SET template_lvl = "-1"

    GET_OFFSET_ARRAY ab_arr SPL_V10_HEADERS
    PHP_EACH ab_arr AS ab_idx => ab_off BEGIN
      READ_SHORT (ab_off + 0x10) ab_lvl
      PATCH_IF (ab_lvl = new_lvl) BEGIN
        SET already_present = 1
      END
      PATCH_IF (ab_lvl <= new_lvl AND ab_lvl > template_lvl) BEGIN
        SET template_lvl = ab_lvl
        SET template_idx = ab_idx
      END
    END

    PATCH_IF (already_present = 0) BEGIN
      PATCH_IF (template_idx < 0) BEGIN
        SET template_idx = 0
      END

      LPF ADD_SPELL_HEADER
        INT_VAR copy_header = template_idx + 1
      RET insert_point
      END

      LPF ALTER_HEADER
        INT_VAR header = insert_point
                level  = new_lvl
                silent = 1
      END

      SET new_dur = new_lvl * units_per_level
      GET_OFFSET_ARRAY ab_arr SPL_V10_HEADERS
      SET new_ab_off = $ab_arr("%insert_point%")
      GET_OFFSET_ARRAY2 fx_arr new_ab_off SPL_V10_HEAD_EFFECTS
      PHP_EACH fx_arr AS fx_idx => fx_off BEGIN
        PATCH_IF (SHORT_AT fx_off = 177) BEGIN
          WRITE_LONG (fx_off + 0x0e) new_dur
        END
      END
    END
  END
END

DEFINE_PATCH_FUNCTION BM_SCALE_DUR_GT30
  INT_VAR true_min = 1
          units_per_level = 0
BEGIN
  LPF FJ_SPL_ITM_REINDEX END

  GET_OFFSET_ARRAY ab_arr SPL_V10_HEADERS
  PHP_EACH ab_arr AS ab_idx => ab_off BEGIN
    READ_SHORT (ab_off + 0x10) ab_min_lvl
    SET eff_level = (ab_min_lvl <= 1) ? true_min : ab_min_lvl
    SET new_dur   = eff_level * units_per_level

    GET_OFFSET_ARRAY2 fx_arr ab_off SPL_V10_HEAD_EFFECTS
    PHP_EACH fx_arr AS fx_idx => fx_off BEGIN
      READ_LONG (fx_off + 0x0e) cur_dur
      PATCH_IF (cur_dur > 30) BEGIN
        WRITE_LONG (fx_off + 0x0e) new_dur
      END
    END
  END

  FOR (new_lvl = true_min; new_lvl <= 20; ++new_lvl) BEGIN
    SET already_present = 0
    SET template_idx = "-1"
    SET template_lvl = "-1"

    GET_OFFSET_ARRAY ab_arr SPL_V10_HEADERS
    PHP_EACH ab_arr AS ab_idx => ab_off BEGIN
      READ_SHORT (ab_off + 0x10) ab_lvl
      PATCH_IF (ab_lvl = new_lvl) BEGIN
        SET already_present = 1
      END
      PATCH_IF (ab_lvl <= new_lvl AND ab_lvl > template_lvl) BEGIN
        SET template_lvl = ab_lvl
        SET template_idx = ab_idx
      END
    END

    PATCH_IF (already_present = 0) BEGIN
      PATCH_IF (template_idx < 0) BEGIN
        SET template_idx = 0
      END

      LPF ADD_SPELL_HEADER
        INT_VAR copy_header = template_idx + 1
      RET insert_point
      END

      LPF ALTER_HEADER
        INT_VAR header = insert_point
                level  = new_lvl
                silent = 1
      END

      SET new_dur = new_lvl * units_per_level
      GET_OFFSET_ARRAY ab_arr SPL_V10_HEADERS
      SET new_ab_off = $ab_arr("%insert_point%")
      GET_OFFSET_ARRAY2 fx_arr new_ab_off SPL_V10_HEAD_EFFECTS
      PHP_EACH fx_arr AS fx_idx => fx_off BEGIN
        READ_LONG (fx_off + 0x0e) cur_dur
        PATCH_IF (cur_dur > 30) BEGIN
          WRITE_LONG (fx_off + 0x0e) new_dur
        END
      END
    END
  END
END

DEFINE_PATCH_FUNCTION BM_SCALE_DIRECT_EXACT
  INT_VAR true_min = 1
          target_opcode = "-1"
          exact_duration = 300
          units_per_level = 0
BEGIN
  LPF FJ_SPL_ITM_REINDEX END

  GET_OFFSET_ARRAY ab_arr SPL_V10_HEADERS
  PHP_EACH ab_arr AS ab_idx => ab_off BEGIN
    READ_SHORT (ab_off + 0x10) ab_min_lvl
    SET eff_level = (ab_min_lvl <= 1) ? true_min : ab_min_lvl
    SET new_dur   = eff_level * units_per_level

    GET_OFFSET_ARRAY2 fx_arr ab_off SPL_V10_HEAD_EFFECTS
    PHP_EACH fx_arr AS fx_idx => fx_off BEGIN
      READ_SHORT (fx_off + 0x00) op
      READ_LONG  (fx_off + 0x0e) cur_dur
      PATCH_IF (cur_dur = exact_duration AND (target_opcode < 0 OR op = target_opcode)) BEGIN
        WRITE_LONG (fx_off + 0x0e) new_dur
      END
    END
  END

  FOR (new_lvl = true_min; new_lvl <= 20; ++new_lvl) BEGIN
    SET already_present = 0
    SET template_idx = "-1"
    SET template_lvl = "-1"

    GET_OFFSET_ARRAY ab_arr SPL_V10_HEADERS
    PHP_EACH ab_arr AS ab_idx => ab_off BEGIN
      READ_SHORT (ab_off + 0x10) ab_lvl
      PATCH_IF (ab_lvl = new_lvl) BEGIN
        SET already_present = 1
      END
      PATCH_IF (ab_lvl <= new_lvl AND ab_lvl > template_lvl) BEGIN
        SET template_lvl = ab_lvl
        SET template_idx = ab_idx
      END
    END

    PATCH_IF (already_present = 0) BEGIN
      PATCH_IF (template_idx < 0) BEGIN
        SET template_idx = 0
      END

      LPF ADD_SPELL_HEADER
        INT_VAR copy_header = template_idx + 1
      RET insert_point
      END

      LPF ALTER_HEADER
        INT_VAR header = insert_point
                level  = new_lvl
                silent = 1
      END

      SET new_dur = new_lvl * units_per_level
      GET_OFFSET_ARRAY ab_arr SPL_V10_HEADERS
      SET new_ab_off = $ab_arr("%insert_point%")
      GET_OFFSET_ARRAY2 fx_arr new_ab_off SPL_V10_HEAD_EFFECTS
      PHP_EACH fx_arr AS fx_idx => fx_off BEGIN
        READ_SHORT (fx_off + 0x00) op
        READ_LONG  (fx_off + 0x0e) cur_dur
        PATCH_IF (cur_dur > 0 AND (target_opcode < 0 OR op = target_opcode)) BEGIN
          WRITE_LONG (fx_off + 0x0e) new_dur
        END
      END
    END
  END
END

DEFINE_PATCH_FUNCTION BM_SCALE_DIRECT_UNITS
  INT_VAR true_min = 1
          target_opcode = "-1"
          units_per_level = 0
          base_units = 0
BEGIN
  LPF FJ_SPL_ITM_REINDEX END

  GET_OFFSET_ARRAY ab_arr SPL_V10_HEADERS
  PHP_EACH ab_arr AS ab_idx => ab_off BEGIN
    READ_SHORT (ab_off + 0x10) ab_min_lvl
    SET eff_level = (ab_min_lvl <= 1) ? true_min : ab_min_lvl
    SET new_dur = (eff_level * units_per_level) + base_units

    GET_OFFSET_ARRAY2 fx_arr ab_off SPL_V10_HEAD_EFFECTS
    PHP_EACH fx_arr AS fx_idx => fx_off BEGIN
      READ_SHORT (fx_off + 0x00) op
      READ_LONG  (fx_off + 0x0e) cur_dur
      PATCH_IF (cur_dur > 0 AND (target_opcode < 0 OR op = target_opcode)) BEGIN
        WRITE_LONG (fx_off + 0x0e) new_dur
      END
    END
  END

  FOR (new_lvl = true_min; new_lvl <= 20; ++new_lvl) BEGIN
    SET already_present = 0
    SET template_idx = "-1"
    SET template_lvl = "-1"

    GET_OFFSET_ARRAY ab_arr SPL_V10_HEADERS
    PHP_EACH ab_arr AS ab_idx => ab_off BEGIN
      READ_SHORT (ab_off + 0x10) ab_lvl
      PATCH_IF (ab_lvl = new_lvl) BEGIN
        SET already_present = 1
      END
      PATCH_IF (ab_lvl <= new_lvl AND ab_lvl > template_lvl) BEGIN
        SET template_lvl = ab_lvl
        SET template_idx = ab_idx
      END
    END

    PATCH_IF (already_present = 0) BEGIN
      PATCH_IF (template_idx < 0) BEGIN
        SET template_idx = 0
      END

      LPF ADD_SPELL_HEADER
        INT_VAR copy_header = template_idx + 1
      RET insert_point
      END

      LPF ALTER_HEADER
        INT_VAR header = insert_point
                level  = new_lvl
                silent = 1
      END

      SET new_dur = (new_lvl * units_per_level) + base_units
      GET_OFFSET_ARRAY ab_arr SPL_V10_HEADERS
      SET new_ab_off = $ab_arr("%insert_point%")
      GET_OFFSET_ARRAY2 fx_arr new_ab_off SPL_V10_HEAD_EFFECTS
      PHP_EACH fx_arr AS fx_idx => fx_off BEGIN
        READ_SHORT (fx_off + 0x00) op
        READ_LONG  (fx_off + 0x0e) cur_dur
        PATCH_IF (cur_dur > 0 AND (target_opcode < 0 OR op = target_opcode)) BEGIN
          WRITE_LONG (fx_off + 0x0e) new_dur
        END
      END
    END
  END
END

DEFINE_PATCH_FUNCTION BM_SCALE_OP321
  INT_VAR true_min = 1
          bonus_turns = 0
          one_turn_units = 0
BEGIN
  LPF FJ_SPL_ITM_REINDEX END

  GET_OFFSET_ARRAY ab_arr SPL_V10_HEADERS
  PHP_EACH ab_arr AS ab_idx => ab_off BEGIN
    READ_SHORT (ab_off + 0x10) ab_min_lvl
    SET eff_level = (ab_min_lvl <= 1) ? true_min : ab_min_lvl
    SET new_dur = (eff_level + bonus_turns) * one_turn_units

    GET_OFFSET_ARRAY2 fx_arr ab_off SPL_V10_HEAD_EFFECTS
    PHP_EACH fx_arr AS fx_idx => fx_off BEGIN
      PATCH_IF (SHORT_AT (fx_off + 0x00) = 321) BEGIN
        WRITE_LONG (fx_off + 0x0e) new_dur
      END
    END
  END

  FOR (new_lvl = true_min; new_lvl <= 20; ++new_lvl) BEGIN
    SET already_present = 0
    SET template_idx = "-1"
    SET template_lvl = "-1"

    GET_OFFSET_ARRAY ab_arr SPL_V10_HEADERS
    PHP_EACH ab_arr AS ab_idx => ab_off BEGIN
      READ_SHORT (ab_off + 0x10) ab_lvl
      PATCH_IF (ab_lvl = new_lvl) BEGIN
        SET already_present = 1
      END
      PATCH_IF (ab_lvl <= new_lvl AND ab_lvl > template_lvl) BEGIN
        SET template_lvl = ab_lvl
        SET template_idx = ab_idx
      END
    END

    PATCH_IF (already_present = 0) BEGIN
      PATCH_IF (template_idx < 0) BEGIN
        SET template_idx = 0
      END

      LPF ADD_SPELL_HEADER
        INT_VAR copy_header = template_idx + 1
      RET insert_point
      END

      LPF ALTER_HEADER
        INT_VAR header = insert_point
                level = new_lvl
                silent = 1
      END

      SET new_dur = (new_lvl + bonus_turns) * one_turn_units
      GET_OFFSET_ARRAY ab_arr SPL_V10_HEADERS
      SET new_ab_off = $ab_arr("%insert_point%")
      GET_OFFSET_ARRAY2 fx_arr new_ab_off SPL_V10_HEAD_EFFECTS
      PHP_EACH fx_arr AS fx_idx => fx_off BEGIN
        PATCH_IF (SHORT_AT (fx_off + 0x00) = 321) BEGIN
          WRITE_LONG (fx_off + 0x0e) new_dur
        END
      END
    END
  END
END

// ---------------------------------------------------------------------------
// Category A: 1 turn/level (OneTurnPerLevel)
// ---------------------------------------------------------------------------

// Summon Duration (op177)
ACTION_FOR_EACH spl IN
  SPWI107 // Monster Summoning I
  SPPR119 // Animal Summoning I
BEGIN
  COPY_EXISTING ~%spl%.spl~ ~override~
    LPF BM_SCALE_OP177 INT_VAR true_min = 1 units_per_level = %OneTurnPerLevel% END
  BUT_ONLY
END

ACTION_FOR_EACH spl IN
  SPWI216 // Monster Summoning II
  SPPR220 // Animal Summoning II
