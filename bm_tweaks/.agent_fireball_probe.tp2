BACKUP ~.agent/working/backup~
AUTHOR ~agent~

BEGIN ~Probe Fireball Resources~

INCLUDE ~bm_tweaks/lib/spl_itm_macros.tpa~

DEFINE_PATCH_FUNCTION BM_DUMP_SPELL
  STR_VAR spl = ""
BEGIN
  PATCH_PRINT ~==== %spl% ====~
  LPF FJ_SPL_ITM_REINDEX END

  GET_OFFSET_ARRAY ab_arr SPL_V10_HEADERS
  PATCH_PRINT ~abilities=%ab_arr%~

  PHP_EACH ab_arr AS ab_idx => ab_off BEGIN
    READ_SHORT (ab_off + 0x10) ab_min_lvl
    READ_SHORT (ab_off + 0x12) ab_loc
    READ_SHORT (ab_off + 0x1e) ab_projectile
    PATCH_PRINT ~  AB[%ab_idx%] minlvl=%ab_min_lvl% location=%ab_loc% proj=%ab_projectile%~

    GET_OFFSET_ARRAY2 fx_arr ab_off SPL_V10_HEAD_EFFECTS
    PATCH_PRINT ~    fx_count=%fx_arr%~
    PHP_EACH fx_arr AS fx_idx => fx_off BEGIN
      READ_SHORT (fx_off + 0x00) op
      READ_LONG  (fx_off + 0x04) p1
      READ_LONG  (fx_off + 0x08) p2
      READ_LONG  (fx_off + 0x0e) dur
      READ_ASCII (fx_off + 0x14) res (8)
      READ_LONG  (fx_off + 0x1c) dice_cnt
      READ_LONG  (fx_off + 0x20) dice_sz
      READ_LONG  (fx_off + 0x24) save_bonus
      PATCH_PRINT ~    FX[%fx_idx%] op=%op% p1=%p1% p2=%p2% dur=%dur% res=%res% dice=%dice_cnt%d%dice_sz% save_bonus=%save_bonus%~
    END
  END
END

COPY_EXISTING ~SPWI304.SPL~ ~override~
  LPF BM_DUMP_SPELL STR_VAR spl = ~SPWI304.SPL~ END
BUT_ONLY

ACTION_IF FILE_EXISTS_IN_GAME ~SPWI304D.SPL~ BEGIN
  COPY_EXISTING ~SPWI304D.SPL~ ~override~
    LPF BM_DUMP_SPELL STR_VAR spl = ~SPWI304D.SPL~ END
  BUT_ONLY
END

ACTION_IF FILE_EXISTS_IN_GAME ~MENECRP3.SPL~ BEGIN
  COPY_EXISTING ~MENECRP3.SPL~ ~override~
    LPF BM_DUMP_SPELL STR_VAR spl = ~MENECRP3.SPL~ END
  BUT_ONLY
END
