// Generated MESpells scroll fallback creation
COPY_EXISTING ~MEWI151.spl~ ~override~
  READ_LONG 0x08 _n
  READ_LONG 0x50 _d
  PATCH_IF (_n > 0 AND _n != 0xffffffff AND _d > 0 AND _d != 0xffffffff) BEGIN
    INNER_ACTION BEGIN
      ACTION_IF (NOT FILE_EXISTS_IN_GAME ~MEWI151X.itm~) AND (NOT FILE_EXISTS_IN_GAME ~BMWI151.itm~) THEN BEGIN
        COPY_EXISTING ~SCRL1R.itm~ ~override/BMWI151.itm~
          WRITE_LONG 0x08 %_n%
          WRITE_LONG 0x0c %_n%
          WRITE_LONG 0x50 0xffffffff
          WRITE_LONG 0x54 %_d%
          READ_LONG  0x64 _ab_off
          READ_SHORT 0x68 _ab_cnt
          READ_LONG  0x6a _fx_off
          FOR (_ab = 0; _ab < _ab_cnt; _ab = (_ab + 1)) BEGIN
            READ_SHORT (_ab_off + _ab * 0x38 + 0x1e) _fx_cnt
            READ_SHORT (_ab_off + _ab * 0x38 + 0x20) _fx_idx
            FOR (_fx = 0; _fx < _fx_cnt; _fx = (_fx + 1)) BEGIN
              READ_SHORT (_fx_off + (_fx_idx + _fx) * 0x30) _op
              PATCH_IF ((_op = 146) OR (_op = 147)) BEGIN
                WRITE_ASCIIE (_fx_off + (_fx_idx + _fx) * 0x30 + 0x14) ~MEWI151~ #8
              END
            END
          END
        BUT_ONLY_IF_IT_CHANGES
        OUTER_SET _wi_created = (_wi_created + 1)
      END
    END
  END
BUT_ONLY

