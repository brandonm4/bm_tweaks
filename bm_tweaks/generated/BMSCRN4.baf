IF
  Global("bmScrollKitInit","LOCALS",0)
THEN
  RESPONSE #100
    SetGlobal("bmScrollKitInit","LOCALS",1)
    SetGlobalTimer("bmScrollKitCleanup","LOCALS",150)
END

IF
  NumTimesTalkedTo(0)
THEN
  RESPONSE #100
    Dialogue(Player4)
END

IF
  NumTimesTalkedTo(1)
THEN
  RESPONSE #100
    DestroySelf()
END

IF
  GlobalTimerExpired("bmScrollKitCleanup","LOCALS")
THEN
  RESPONSE #100
    DestroySelf()
END
